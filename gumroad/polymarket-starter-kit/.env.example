# Polymarket Credentials
# Get your private key from MetaMask or export from Polymarket
POLYMARKET_PRIVATE_KEY=your_private_key_here

# Your Polygon wallet address (where your USDC lives)
POLYMARKET_FUNDER_ADDRESS=0xYourWalletAddressHere

# Chain ID: 137 = Polygon Mainnet (don't change this)
CHAIN_ID=137

# Risk Limits (all percentage-based — scale with your balance)
MAX_BET_PCT=0.20        # Max 20% of balance per single trade
DAILY_LOSS_PCT=0.30     # Stop trading if down 30% in a day
MAX_POSITION_PCT=0.50   # Max 50% of balance in one market

# Optional: API credentials (not required for basic trading)
# POLYMARKET_API_KEY=
# POLYMARKET_API_SECRET=
# POLYMARKET_API_PASSPHRASE=
